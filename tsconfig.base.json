{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM"],
    "declaration": true,
    "strict": true,
    "baseUrl": "./",
    "ignoreDeprecations": "5.0",

    "paths": {
      "@web/*": ["packages/web/src/*"],
      "@tokens/*": ["packages/tokens/src/*"],
      "@utils/*": ["packages/utils/src/*"]
    }
  }
}
