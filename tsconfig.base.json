{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM"],
    "declaration": true,
    "strict": true,

    "paths": {
      "@web/*": ["./packages/web/src/*"],
      "@tokens/*": ["./packages/tokens/src/*"],
      "@utils/*": ["./packages/utils/src/*"]
    }
  }
}
