{
  "name": "latty",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @latty/tokens build && pnpm docs:dev",
    "docs:dev": "pnpm --filter @latty/docs dev",
    "docs:build": "pnpm --filter @latty/utils build && pnpm --filter @latty/tokens build && pnpm --filter @latty/icons build && pnpm --filter @latty/web build && pnpm --filter @latty/docs build",
    "docs:preview": "pnpm --filter @latty/docs preview",
    "clean": "pnpm -r clean",
    "lint": "eslint packages",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "codegen:wrappers": "node scripts/codegen-wrappers.mjs",
    "bundle-size": "node scripts/bundle-size.mjs",
    "bundle-size:update": "node scripts/bundle-size.mjs --update",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,mts,cts,js,mjs,cjs,json,md,css}": "eslint --fix",
    "*.astro": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^9.39.2",
    "@eslint/json": "^0.14.0",
    "@eslint/markdown": "^7.5.1",
    "@latty/utils": "workspace:^",
    "@open-wc/testing": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.10",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/ui": "^4.0.17",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.2",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.4.0",
    "lit": "^3.2.0",
    "prettier": "^3.8.0",
    "prettier-plugin-astro": "^0.14.1",
    "react": "^18",
    "react-dom": "^18",
    "tiny-invariant": "^1.3.3",
    "ts-dedent": "^2.2.0",
    "tsc-alias": "^1.8.16",
    "tsup": "^8.5.1",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.53.1",
    "vite": "^6",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.18"
  }
}
