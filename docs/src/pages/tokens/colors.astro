---
import BaseLayout from '../../layouts/BaseLayout.astro';
import tokens from '@latty/tokens/tokens.json';

const color = (tokens as any).color;

const semanticPalettes = ['primary', 'secondary', 'success', 'warning', 'error', 'info', 'neutral'];
const shades = ['50', '100', '200', '300', '400', '500', '600', '700', '800', '900'];

function textColor(shade: string) {
  return Number(shade) >= 500 ? '#fff' : '#1b1b1b';
}
---

<BaseLayout title="Colors" description="Color tokens in the Latty Design System">
  <h1>Colors</h1>
  <p>
    Each semantic color is auto-generated from a single base hex value using the OKLCH color space,
    producing 10 perceptually uniform shades (50–900) plus a muted variant.
  </p>

  {semanticPalettes.map((palette) => (
    <section class="palette-section">
      <h2 class="palette-name">{palette}</h2>

      <!-- Main palette -->
      <p class="sub-label">Default</p>
      <div class="palette-row">
        {shades.map((shade) => {
          const hex = color[palette]?.[shade];
          if (!hex) return null;
          return (
            <div class="swatch-wrap">
              <div class="swatch" style={`background: ${hex};`}></div>
              <span class="swatch-shade" style={`color: ${textColor(shade) === '#fff' ? 'var(--lt-color-neutral-600)' : 'var(--lt-color-neutral-600)'}`}>{shade}</span>
              <span class="swatch-hex">{hex}</span>
            </div>
          );
        })}
      </div>

      <!-- Muted palette -->
      {color[`${palette}-muted`] && (
        <>
          <p class="sub-label">Muted</p>
          <div class="palette-row">
            {shades.map((shade) => {
              const hex = color[`${palette}-muted`]?.[shade];
              if (!hex) return null;
              return (
                <div class="swatch-wrap">
                  <div class="swatch" style={`background: ${hex};`}></div>
                  <span class="swatch-shade">{shade}</span>
                  <span class="swatch-hex">{hex}</span>
                </div>
              );
            })}
          </div>
        </>
      )}
    </section>
  ))}
</BaseLayout>

<style>
  .palette-section {
    margin-bottom: var(--lt-spacing-10);
  }

  .palette-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--lt-color-neutral-900);
    text-transform: capitalize;
    margin-bottom: var(--lt-spacing-3);
    padding-bottom: var(--lt-spacing-2);
    border-bottom: 1px solid var(--lt-color-neutral-200);
  }

  .sub-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--lt-color-neutral-400);
    margin-bottom: var(--lt-spacing-2);
  }

  .palette-row {
    display: grid;
    grid-template-columns: repeat(10, 1fr);
    gap: var(--lt-spacing-2);
    margin-bottom: var(--lt-spacing-4);
  }

  .swatch-wrap {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
    overflow: hidden;
  }

  .swatch {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 6px;
    border: 1px solid rgba(0, 0, 0, 0.06);
  }

  .swatch-shade {
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--lt-color-neutral-500);
    text-align: center;
    white-space: nowrap;
  }

  .swatch-hex {
    font-size: 0.6rem;
    font-family: monospace;
    color: var(--lt-color-neutral-400);
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    width: 100%;
  }

  @media (max-width: 640px) {
    .palette-row {
      grid-template-columns: repeat(5, 1fr);
    }
  }
</style>
