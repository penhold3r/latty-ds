---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ComponentPlayground from '../../../components/ComponentPlayground.astro';
import FrameworkTabs from '../../../components/FrameworkTabs.astro';
import ApiTable from '../../../components/ApiTable.astro';
---

<BaseLayout title="Checkbox" description="Checkbox input component">
  <h1>Checkbox</h1>
  <p>A checkbox input with support for checked, indeterminate, and disabled states across multiple variants.</p>

  <h2>Playground</h2>
  <ComponentPlayground tag="lt-checkbox" />

  <h2>Usage</h2>
  <FrameworkTabs
    html={`
<lt-checkbox label="Accept terms and conditions"></lt-checkbox>
<lt-checkbox label="Enable notifications" variant="success" checked></lt-checkbox>
<lt-checkbox label="Unavailable option" disabled></lt-checkbox>
    `}
    react={`
import { Checkbox } from '@latty/react';

<Checkbox label="Accept terms and conditions" />
<Checkbox label="Enable notifications" variant="success" checked />
<Checkbox label="Unavailable option" disabled />
    `}
  />

  <h2>API</h2>
  <ApiTable tag="lt-checkbox" />
</BaseLayout>

<script>import '@latty/web';</script>
