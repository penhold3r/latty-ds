# Table

The Table component provides a responsive data table with sortable columns, multiple display modes, and extensive customization options.

## Examples

### Basic Table

<div id="basic-table-demo" style="margin: var(--lt-spacing-4) 0;"></div>

```html
<lt-table></lt-table>

<script>
  const table = document.querySelector('lt-table');
  table.columns = [
    { key: 'name', label: 'Name', sortable: true },
    { key: 'email', label: 'Email', sortable: true },
    { key: 'role', label: 'Role', sortable: true },
  ];
  table.data = [
    { name: 'John Doe', email: 'john@example.com', role: 'Developer' },
    { name: 'Jane Smith', email: 'jane@example.com', role: 'Designer' },
    { name: 'Bob Johnson', email: 'bob@example.com', role: 'Manager' },
  ];
</script>
```

### Sortable Columns

Click on column headers to sort the data.

<div id="sortable-table-demo" style="margin: var(--lt-spacing-4) 0;"></div>

### Striped & Hoverable

<div id="striped-table-demo" style="margin: var(--lt-spacing-4) 0;"></div>

```html
<lt-table striped hoverable bordered></lt-table>
```

### Density Options

<div style="margin: var(--lt-spacing-4) 0;">
  <h4>Compact</h4>
  <div id="compact-table-demo" style="margin: var(--lt-spacing-3) 0;"></div>
  
  <h4>Normal</h4>
  <div id="normal-table-demo" style="margin: var(--lt-spacing-3) 0;"></div>
  
  <h4>Comfortable</h4>
  <div id="comfortable-table-demo" style="margin: var(--lt-spacing-3) 0;"></div>
</div>

```html
<lt-table density="compact"></lt-table>
<lt-table density="normal"></lt-table>
<lt-table density="comfortable"></lt-table>
```

### Responsive Modes

The table supports two responsive modes:

- **scroll** - Horizontal scrolling on small screens (default)
- **stack** - Converts to card layout on mobile

```html
<lt-table responsive-mode="scroll"></lt-table>
<lt-table responsive-mode="stack"></lt-table>
```

## Properties

| Property | Type | Default | Description |
|----------|------|---------|-------------|
| `columns` | `TableColumn[]` | `[]` | Column definitions |
| `data` | `T[]` | `[]` | Data rows |
| `density` | `'compact' \| 'normal' \| 'comfortable'` | `'normal'` | Table spacing |
| `responsive-mode` | `'scroll' \| 'stack'` | `'scroll'` | Responsive behavior |
| `hoverable` | `boolean` | `false` | Row hover effect |
| `striped` | `boolean` | `false` | Zebra stripes |
| `bordered` | `boolean` | `false` | Cell borders |
| `loading` | `boolean` | `false` | Loading state |
| `empty-message` | `string` | `'No data available'` | Empty state message |

## Column Definition

```typescript
interface TableColumn<T> {
  key: string;
  label: string;
  sortable?: boolean;
  sortFn?: (a: T, b: T, direction: 'asc' | 'desc') => number;
  width?: string;
  minWidth?: string;
  align?: 'left' | 'center' | 'right';
  hideOnMobile?: boolean;
  render?: (value: any, row: T, index: number) => string | HTMLElement;
  sticky?: boolean;
}
```

## Events

| Event | Detail | Description |
|-------|--------|-------------|
| `lt-sort-change` | `{ key: string, direction: 'asc' \| 'desc' }` | Fired when sort changes |

## Features

- ✅ Sortable columns
- ✅ Custom sort functions
- ✅ Custom cell renderers
- ✅ Sticky columns
- ✅ Responsive modes (scroll/stack)
- ✅ Three density levels
- ✅ Zebra striping
- ✅ Row hover effects
- ✅ Loading and empty states
- ✅ Keyboard navigation

<script is:inline type="module">
  import '@latty/web';

  const sampleData = [
    { name: 'John Doe', email: 'john@example.com', role: 'Developer', age: 30 },
    { name: 'Jane Smith', email: 'jane@example.com', role: 'Designer', age: 28 },
    { name: 'Bob Johnson', email: 'bob@example.com', role: 'Manager', age: 35 },
    { name: 'Alice Williams', email: 'alice@example.com', role: 'Developer', age: 32 },
  ];

  const basicColumns = [
    { key: 'name', label: 'Name', sortable: true },
    { key: 'email', label: 'Email', sortable: true },
    { key: 'role', label: 'Role', sortable: true },
  ];

  // Basic table
  const basicTable = document.createElement('lt-table');
  basicTable.columns = basicColumns;
  basicTable.data = sampleData.slice(0, 3);
  const basicDemo = document.getElementById('basic-table-demo');
  if (basicDemo) basicDemo.appendChild(basicTable);

  // Sortable table
  const sortableTable = document.createElement('lt-table');
  sortableTable.columns = [
    { key: 'name', label: 'Name', sortable: true },
    { key: 'email', label: 'Email', sortable: true },
    { key: 'role', label: 'Role', sortable: true },
    { key: 'age', label: 'Age', sortable: true, align: 'right' },
  ];
  sortableTable.data = sampleData;
  sortableTable.hoverable = true;
  const sortableDemo = document.getElementById('sortable-table-demo');
  if (sortableDemo) sortableDemo.appendChild(sortableTable);

  // Striped table
  const stripedTable = document.createElement('lt-table');
  stripedTable.columns = basicColumns;
  stripedTable.data = sampleData;
  stripedTable.striped = true;
  stripedTable.hoverable = true;
  stripedTable.bordered = true;
  const stripedDemo = document.getElementById('striped-table-demo');
  if (stripedDemo) stripedDemo.appendChild(stripedTable);

  // Density tables
  ['compact', 'normal', 'comfortable'].forEach((density) => {
    const table = document.createElement('lt-table');
    table.columns = basicColumns;
    table.data = sampleData.slice(0, 2);
    table.density = density;
    table.bordered = true;
    const demo = document.getElementById(`${density}-table-demo`);
    if (demo) demo.appendChild(table);
  });
</script>
