---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Button" description="Interactive button component with multiple variants and states">
  <h1>Button</h1>

  <p>The Button component provides an interactive button element with multiple variants, sizes, and states.</p>

  <h2>Examples</h2>

  <h3>Basic Button</h3>

  <div style="display: flex; gap: var(--lt-spacing-3); margin: var(--lt-spacing-4) 0; flex-wrap: wrap;">
    <lt-button>Default</lt-button>
    <lt-button variant="primary">Primary</lt-button>
    <lt-button variant="secondary">Secondary</lt-button>
    <lt-button variant="danger">Danger</lt-button>
    <lt-button variant="ghost">Ghost</lt-button>
  </div>

  <pre><code class="language-html">&lt;lt-button&gt;Default&lt;/lt-button&gt;
&lt;lt-button variant="primary"&gt;Primary&lt;/lt-button&gt;
&lt;lt-button variant="secondary"&gt;Secondary&lt;/lt-button&gt;
&lt;lt-button variant="danger"&gt;Danger&lt;/lt-button&gt;
&lt;lt-button variant="ghost"&gt;Ghost&lt;/lt-button&gt;</code></pre>

  <h3>Sizes</h3>

  <div style="display: flex; gap: var(--lt-spacing-3); align-items: center; margin: var(--lt-spacing-4) 0; flex-wrap: wrap;">
    <lt-button size="sm" variant="primary">Small</lt-button>
    <lt-button size="md" variant="primary">Medium</lt-button>
    <lt-button size="lg" variant="primary">Large</lt-button>
  </div>

  <h3>With Icons</h3>

  <div style="display: flex; gap: var(--lt-spacing-3); margin: var(--lt-spacing-4) 0; flex-wrap: wrap;">
    <lt-button variant="primary" icon="save">Save</lt-button>
    <lt-button variant="secondary" icon="download">Download</lt-button>
    <lt-button variant="danger" icon="trash">Delete</lt-button>
  </div>

  <h2>Properties</h2>

  <table style="width: 100%; border-collapse: collapse; margin: var(--lt-spacing-4) 0;">
    <thead>
      <tr style="border-bottom: 2px solid var(--lt-color-neutral-300);">
        <th style="text-align: left; padding: var(--lt-spacing-2);">Property</th>
        <th style="text-align: left; padding: var(--lt-spacing-2);">Type</th>
        <th style="text-align: left; padding: var(--lt-spacing-2);">Default</th>
        <th style="text-align: left; padding: var(--lt-spacing-2);">Description</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td style="padding: var(--lt-spacing-2);"><code>variant</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>'default' | 'primary' | 'secondary' | 'danger' | 'ghost'</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>'default'</code></td>
        <td style="padding: var(--lt-spacing-2);">Visual style variant</td>
      </tr>
      <tr>
        <td style="padding: var(--lt-spacing-2);"><code>size</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>'sm' | 'md' | 'lg'</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>'md'</code></td>
        <td style="padding: var(--lt-spacing-2);">Button size</td>
      </tr>
      <tr>
        <td style="padding: var(--lt-spacing-2);"><code>icon</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>string</code></td>
        <td style="padding: var(--lt-spacing-2);">-</td>
        <td style="padding: var(--lt-spacing-2);">Icon name to display</td>
      </tr>
      <tr>
        <td style="padding: var(--lt-spacing-2);"><code>loading</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>boolean</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>false</code></td>
        <td style="padding: var(--lt-spacing-2);">Shows loading spinner</td>
      </tr>
      <tr>
        <td style="padding: var(--lt-spacing-2);"><code>disabled</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>boolean</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>false</code></td>
        <td style="padding: var(--lt-spacing-2);">Disables the button</td>
      </tr>
    </tbody>
  </table>
</BaseLayout>

<script>
  import '@latty/web';
</script>
