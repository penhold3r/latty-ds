---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Dialog" description="Modal dialog component with customizable size and behavior">
  <h1>Dialog</h1>

  <p>The Dialog component provides a modal dialog with backdrop, customizable sizes, and full accessibility support including focus trapping and keyboard navigation.</p>

  <h2>Basic Example</h2>

  <pre><code class="language-html">&lt;lt-button id="open-dialog"&gt;Open Dialog&lt;/lt-button&gt;

&lt;lt-dialog id="my-dialog" title="Welcome"&gt;
  &lt;p&gt;Dialog content here&lt;/p&gt;
  &lt;div slot="footer"&gt;
    &lt;lt-button id="close-dialog"&gt;OK&lt;/lt-button&gt;
  &lt;/div&gt;
&lt;/lt-dialog&gt;

&lt;script&gt;
  document.getElementById('open-dialog').addEventListener('click', () => &#123;
    document.getElementById('my-dialog').show();
  &#125;);
  document.getElementById('close-dialog').addEventListener('click', () => &#123;
    document.getElementById('my-dialog').hide();
  &#125;);
&lt;/script&gt;</code></pre>

  <h2>Sizes</h2>

  <p>Available sizes: <code>sm</code>, <code>md</code> (default), <code>lg</code>, <code>xl</code>, <code>fullscreen</code></p>

  <pre><code class="language-html">&lt;lt-dialog size="sm"&gt;Small&lt;/lt-dialog&gt;
&lt;lt-dialog size="md"&gt;Medium (default)&lt;/lt-dialog&gt;
&lt;lt-dialog size="lg"&gt;Large&lt;/lt-dialog&gt;
&lt;lt-dialog size="xl"&gt;Extra Large&lt;/lt-dialog&gt;
&lt;lt-dialog size="fullscreen"&gt;Fullscreen&lt;/lt-dialog&gt;</code></pre>

  <h2>Properties</h2>

  <table style="width: 100%; border-collapse: collapse; margin: var(--lt-spacing-4) 0;">
    <thead>
      <tr style="border-bottom: 2px solid var(--lt-color-neutral-300);">
        <th style="text-align: left; padding: var(--lt-spacing-2);">Property</th>
        <th style="text-align: left; padding: var(--lt-spacing-2);">Type</th>
        <th style="text-align: left; padding: var(--lt-spacing-2);">Default</th>
        <th style="text-align: left; padding: var(--lt-spacing-2);">Description</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td style="padding: var(--lt-spacing-2);"><code>open</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>boolean</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>false</code></td>
        <td style="padding: var(--lt-spacing-2);">Controls dialog visibility</td>
      </tr>
      <tr>
        <td style="padding: var(--lt-spacing-2);"><code>title</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>string</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>''</code></td>
        <td style="padding: var(--lt-spacing-2);">Dialog title</td>
      </tr>
      <tr>
        <td style="padding: var(--lt-spacing-2);"><code>size</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>'sm' | 'md' | 'lg' | 'xl' | 'fullscreen'</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>'md'</code></td>
        <td style="padding: var(--lt-spacing-2);">Dialog size</td>
      </tr>
      <tr>
        <td style="padding: var(--lt-spacing-2);"><code>hide-close-button</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>boolean</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>false</code></td>
        <td style="padding: var(--lt-spacing-2);">Hides the close button</td>
      </tr>
      <tr>
        <td style="padding: var(--lt-spacing-2);"><code>close-on-backdrop-click</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>boolean</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>true</code></td>
        <td style="padding: var(--lt-spacing-2);">Close when clicking backdrop</td>
      </tr>
      <tr>
        <td style="padding: var(--lt-spacing-2);"><code>close-on-escape</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>boolean</code></td>
        <td style="padding: var(--lt-spacing-2);"><code>true</code></td>
        <td style="padding: var(--lt-spacing-2);">Close when pressing Escape</td>
      </tr>
    </tbody>
  </table>

  <h2>Methods</h2>

  <table style="width: 100%; border-collapse: collapse; margin: var(--lt-spacing-4) 0;">
    <thead>
      <tr style="border-bottom: 2px solid var(--lt-color-neutral-300);">
        <th style="text-align: left; padding: var(--lt-spacing-2);">Method</th>
        <th style="text-align: left; padding: var(--lt-spacing-2);">Description</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td style="padding: var(--lt-spacing-2);"><code>show()</code></td>
        <td style="padding: var(--lt-spacing-2);">Opens the dialog</td>
      </tr>
      <tr>
        <td style="padding: var(--lt-spacing-2);"><code>hide()</code></td>
        <td style="padding: var(--lt-spacing-2);">Closes the dialog</td>
      </tr>
      <tr>
        <td style="padding: var(--lt-spacing-2);"><code>toggle()</code></td>
        <td style="padding: var(--lt-spacing-2);">Toggles dialog visibility</td>
      </tr>
    </tbody>
  </table>

  <h2>Events</h2>

  <table style="width: 100%; border-collapse: collapse; margin: var(--lt-spacing-4) 0;">
    <thead>
      <tr style="border-bottom: 2px solid var(--lt-color-neutral-300);">
        <th style="text-align: left; padding: var(--lt-spacing-2);">Event</th>
        <th style="text-align: left; padding: var(--lt-spacing-2);">Description</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td style="padding: var(--lt-spacing-2);"><code>lt-open</code></td>
        <td style="padding: var(--lt-spacing-2);">Fired when dialog opens</td>
      </tr>
      <tr>
        <td style="padding: var(--lt-spacing-2);"><code>lt-close</code></td>
        <td style="padding: var(--lt-spacing-2);">Fired when dialog closes</td>
      </tr>
    </tbody>
  </table>

  <h2>Accessibility</h2>

  <ul>
    <li>Focus trap keeps focus within dialog</li>
    <li>Escape key closes dialog (configurable)</li>
    <li>Backdrop click closes dialog (configurable)</li>
    <li>Body scroll is prevented when open</li>
    <li>Proper ARIA attributes (<code>role="dialog"</code>, <code>aria-modal="true"</code>)</li>
    <li>Focus is returned to trigger element on close</li>
  </ul>
</BaseLayout>

<script>
  import '@latty/web';
</script>
