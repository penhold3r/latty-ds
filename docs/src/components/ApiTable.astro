---
import manifest from '@latty/web/manifest.json';

interface Props {
  tag: string;
}

const { tag } = Astro.props;
const component = (manifest as any)[tag];
const members = component?.members ?? [];

function formatType(member: any): string {
  if (member.type === 'select' && member.options) {
    return member.options.map((o: string) => `'${o}'`).join(' | ');
  }
  return member.type;
}

function formatDefault(member: any): string {
  const d = member.default;
  if (d === undefined || d === '') return '—';
  if (typeof d === 'boolean') return String(d);
  return `'${d}'`;
}
---

<div class="api-table-wrap">
  <table class="api-table">
    <thead>
      <tr>
        <th>Property</th>
        <th>Type</th>
        <th>Default</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      {members.map((member: any) => (
        <tr>
          <td><code class="prop-name">{member.name}</code></td>
          <td><code class="prop-type">{formatType(member)}</code></td>
          <td><code class="prop-default">{formatDefault(member)}</code></td>
          <td class="prop-desc">{member.description}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .api-table-wrap {
    overflow-x: auto;
    margin: var(--lt-spacing-4) 0;
    border: 1px solid var(--lt-color-neutral-200);
    border-radius: 8px;
  }

  .api-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .api-table thead {
    background: var(--lt-color-neutral-100);
  }

  .api-table th {
    text-align: left;
    padding: var(--lt-spacing-3) var(--lt-spacing-4);
    font-weight: 600;
    color: var(--lt-color-neutral-700);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--lt-color-neutral-200);
    white-space: nowrap;
  }

  .api-table td {
    padding: var(--lt-spacing-3) var(--lt-spacing-4);
    border-bottom: 1px solid var(--lt-color-neutral-100);
    vertical-align: top;
  }

  .api-table tr:last-child td {
    border-bottom: none;
  }

  .api-table tr:hover td {
    background: var(--lt-color-neutral-50);
  }

  .prop-name {
    color: var(--lt-color-primary-700);
    white-space: nowrap;
  }

  .prop-type {
    color: var(--lt-color-secondary-700);
    font-size: 0.8125rem;
  }

  .prop-default {
    color: var(--lt-color-neutral-600);
    white-space: nowrap;
  }

  .prop-desc {
    color: var(--lt-color-neutral-700);
    line-height: 1.5;
  }
</style>
