{
  "name": "@latty/tokens",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/public-types.d.ts",
  "exports": {
    ".": {
      "types": "./dist/public-types.d.ts",
      "default": "./dist/index.js"
    },
    "./configure": {
      "types": "./dist/configure.d.ts",
      "default": "./dist/configure.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./semantic.css": "./dist/semantic.css",
    "./tokens.json": "./dist/tokens.json"
  },
  "scripts": {
    "build": "pnpm run build:scripts && pnpm run build:tokens && pnpm run build:types",
    "build:scripts": "tsup",
    "build:tokens": "node ./dist-scripts/tokens.js",
    "build:types": "tsc -p tsconfig.types.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist dist-scripts"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@latty/utils": "workspace:*",
    "@types/culori": "^4.0.1",
    "culori": "^4.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
